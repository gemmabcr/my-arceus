#!/bin/sh

if [ "$(uname -s)" = "Darwin" ] && [ -x /usr/libexec/java_home ]; then
  JAVA_HOME=$(/usr/libexec/java_home -v 17 2>/dev/null)
  if [ -z "$JAVA_HOME" ]; then
    echo "❌ Cal tenir instal·lat Java 17 per validar el projecte."
    exit 1
  fi
  export JAVA_HOME
fi

./gradlew detekt

DETekt_STATUS=$?

if [ $DETekt_STATUS -ne 0 ]; then
  echo "❌ Detekt ha detectat problemes. Commit cancel·lat."
  exit 1
fi

echo "🔍 Executant build i tests amb Gradle..."

./gradlew build

STATUS=$?

if [ $STATUS -ne 0 ]; then
  echo "❌ Build o tests han fallat. Commit cancel·lat."
  exit 1
fi

echo "✅ Tot correcte. Continuant amb el commit."
exit 0
